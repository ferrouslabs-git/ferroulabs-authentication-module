# Auth Module Sandbox - Environment Configuration Template
# Copy this to backend/.env and frontend/.env with your actual values

# =============================================================================
# BACKEND CONFIGURATION (backend/.env)
# =============================================================================

# AWS Cognito Configuration
# Get these from AWS Console → Cognito → User Pools
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=your-pool-id-here
COGNITO_CLIENT_ID=your-client-id-here

# Database Configuration
# PostgreSQL connection string
# Use setup-postgres.ps1 to create a local database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/your_database_name

# AWS SES Configuration (optional - for email invitations)
SES_REGION=eu-west-1
SES_SENDER_EMAIL=noreply@example.com

# Frontend URL (for invitation links in emails)
FRONTEND_URL=http://localhost:5173

# Cookie security (true for production HTTPS, false for local HTTP)
COOKIE_SECURE=true

# Host-owned CORS origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth module settings
AUTH_MODE=hosted_ui          # hosted_ui (default) or custom_ui
AUTH_NAMESPACE=authum        # Cookie name prefix
AUTH_API_PREFIX=/auth        # Route mount point
# AUTH_CONFIG_PATH=          # Custom path to auth_config.yaml (optional)

# =============================================================================
# FRONTEND CONFIGURATION (frontend/.env)
# =============================================================================

# Vite requires VITE_ prefix for environment variables

# AWS Cognito (must match backend)
VITE_COGNITO_REGION=eu-west-1
VITE_COGNITO_USER_POOL_ID=your-pool-id-here
VITE_COGNITO_CLIENT_ID=your-client-id-here
VITE_COGNITO_DOMAIN=https://your-pool-domain.auth.eu-west-1.amazoncognito.com

# Backend API URL
VITE_API_BASE_URL=http://localhost:8001

# OAuth Redirect URI (must be registered in Cognito App Client settings)
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback

# Auth mode (match backend AUTH_MODE setting)
# VITE_AUTH_MODE=custom_ui

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file to backend/.env:
#    cp .env.example backend/.env
#
# 2. Copy this file to frontend/.env:
#    cp .env.example frontend/.env
#
# 3. Edit both files with your actual AWS Cognito values
#
# 4. Run setup-postgres.ps1 to create local database
#
# 5. Run database migrations:
#    cd backend
#    alembic upgrade head
#
# 6. Start backend:
#    cd backend
#    python -m uvicorn app.main:app --host 127.0.0.1 --port 8001 --reload
#
# 7. Start frontend:
#    cd frontend
#    npm install
#    npm run dev
#
