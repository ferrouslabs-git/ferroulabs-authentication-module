# Cognito Settings (Required)
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=eu-west-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=https://your-domain.auth.eu-west-1.amazoncognito.com

# Database Settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustos

# AWS SES Settings (Required for invitation emails)
SES_REGION=eu-west-1
SES_SENDER_EMAIL=ali@ferrouslabs.co.uk

# Frontend URL (for invitation links in emails)
FRONTEND_URL=http://localhost:5173

# Cookie security
# Use true in production (HTTPS). For local HTTP development only, set false.
COOKIE_SECURE=true

# Host-owned CORS origins (comma-separated)
# Set explicit origins per environment, e.g. https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
